---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero";
import Summary from "../components/Summary";
import TechnicalSkills from "../components/TechnicalSkills";
import Experience from "../components/Experience";
---

<Layout title="Crazy">
    <main class="relative container mx-auto px-4 sm:px-6 py-10 sm:py-32 max-w-5xl">
        <div
            class="hidden lg:block absolute top-0 bottom-0 left-0 w-px bg-[linear-gradient(to_bottom,transparent_0%,var(--color-card)_15%,var(--color-card)_85%,transparent_100%)] opacity-[0.08] pointer-events-none"
        >
        </div>
        <div
            class="hidden lg:block absolute top-0 bottom-0 right-0 w-px bg-[linear-gradient(to_bottom,transparent_0%,var(--color-card)_15%,var(--color-card)_85%,transparent_100%)] opacity-[0.08] pointer-events-none"
        >
        </div>

        <div
            class="min-h-[calc(100dvh-5rem)] sm:min-h-[calc(100vh-8rem)] flex flex-col justify-center"
        >
            <Hero client:load />
            <Summary client:visible />
        </div>
        <div class="space-y-16">
            <TechnicalSkills client:visible />
            <Experience client:visible />
        </div>

        <!-- Subtle End Indicator -->
        <div
            class="mt-20 sm:mt-28 flex justify-center opacity-30 hover:opacity-50 transition-opacity duration-300"
        >
            <div class="flex gap-4">
                <span class="w-1.5 h-1.5 rounded-full bg-muted"></span>
                <span class="w-1.5 h-1.5 rounded-full bg-muted"></span>
                <span class="w-1.5 h-1.5 rounded-full bg-muted"></span>
            </div>
        </div>
    </main>
</Layout>
