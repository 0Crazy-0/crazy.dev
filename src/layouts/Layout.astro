---
import "../styles/global.css";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Backend developer. C# and .NET. Building things that work."
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/heart.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
		<noscript>
			<link
				rel="stylesheet"
				href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap"
			/>
		</noscript>
	</head>
	<body class="min-h-screen overflow-x-hidden">
		<!-- Mobile orbs -->
		<div
			class="sm:hidden fixed rounded-full pointer-events-none blur-[80px] z-0 w-[200px] h-[200px] bg-[#b8976a] opacity-[0.08] -top-[5%] -right-[5%]"
			aria-hidden="true"
		>
		</div>
		<div
			class="sm:hidden fixed rounded-full pointer-events-none blur-[80px] z-0 w-[200px] h-[200px] bg-[#7a6f5a] opacity-[0.10] bottom-[8%] -left-[5%]"
			aria-hidden="true"
		>
		</div>
		<!-- Desktop orbs -->
		<div
			class="hidden sm:block fixed rounded-full pointer-events-none blur-[140px] z-0 w-[550px] h-[550px] bg-[#b8976a] opacity-[0.08] -top-[5%] -right-[8%]"
			aria-hidden="true"
		>
		</div>
		<div
			class="hidden sm:block fixed rounded-full pointer-events-none blur-[140px] z-0 w-[650px] h-[650px] bg-[#7a6f5a] opacity-[0.12] bottom-[10%] -left-[10%]"
			aria-hidden="true"
		>
		</div>
		<div
			class="hidden sm:block fixed rounded-full pointer-events-none blur-[140px] z-0 w-[450px] h-[450px] bg-[#c4a67a] opacity-[0.07] top-[50%] right-[5%]"
			aria-hidden="true"
		>
		</div>

		<div class="relative z-10">
			<slot />
		</div>
	</body>
</html>
